@page "/"
@implements IAsyncDisposable
@inject IIssApiService IssApi
@inject IReverseGeocodingService ReverseGeocoding
@inject IJSRuntime JS

<PageTitle>ISS Mission Board</PageTitle>

<div class="dashboard-header mb-4">
    <div>
        <span class="eyebrow">International Space Station</span>
        <h1>ISS Mission Board</h1>
    </div>
    <div class="d-flex align-items-center gap-2">
        @if (_isRefreshing && !_isInitialLoading)
        {
            <span class="spinner-border spinner-border-sm text-primary" role="status" aria-label="Aktualisierung läuft"></span>
        }
        <span class="badge rounded-pill text-bg-success">5s Live</span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @_errorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(_mapErrorMessage))
{
    <div class="alert alert-warning" role="alert">
        @_mapErrorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(_locationWarning))
{
    <div class="alert alert-warning" role="alert">
        @_locationWarning
    </div>
}

@if (!string.IsNullOrWhiteSpace(_storageWarning))
{
    <div class="alert alert-warning" role="alert">
        @_storageWarning
    </div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card telemetry-card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">Live Telemetrie</h2>
                <span class="badge text-bg-dark">Open Notify</span>
            </div>
            <div class="card-body">
                @if (_isInitialLoading)
                {
                    <div class="loading-block">
                        <div class="spinner-border text-primary" role="status" aria-label="ISS-Daten werden geladen"></div>
                        <div>
                            <div class="fw-semibold">ISS-Daten werden geladen</div>
                            <div class="text-secondary small">Positionsdaten und Region</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="metric-group">
                        <div>
                            <div class="metric-label">Latitude</div>
                            <div class="metric-value">@FormatCoordinate(_telemetry?.Latitude, 'N', 'S')</div>
                        </div>
                        <div>
                            <div class="metric-label">Longitude</div>
                            <div class="metric-value">@FormatCoordinate(_telemetry?.Longitude, 'E', 'W')</div>
                        </div>
                    </div>

                    <hr />

                    <div class="metric-label">Region</div>
                    <div class="location-value">@(_telemetry?.LocationLabel ?? "Unbekannt")</div>

                    <div class="mt-4 d-flex flex-wrap gap-2">
                        <span class="badge text-bg-primary">Update @_telemetry?.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                        <span class="badge text-bg-secondary">@_flightPath.Count/50 Trackpunkte</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card map-card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">Weltkarte</h2>
                <span class="badge text-bg-warning">Route gespeichert</span>
            </div>
            <div class="map-shell">
                <div id="iss-map"></div>
                @if (_isInitialLoading)
                {
                    <div class="map-loading-overlay">
                        <div class="spinner-border text-light" role="status" aria-label="Karte wird geladen"></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-md-6 col-xl-4">
        <div class="card telemetry-card h-100">
            <div class="card-body">
                <div class="metric-label">Letzte Aktualisierung</div>
                <div class="support-value">@(_telemetry?.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") ?? "--")</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card telemetry-card h-100">
            <div class="card-body">
                <div class="metric-label">Datenquelle</div>
                <div class="support-value">Open Notify + BigDataCloud</div>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card telemetry-card h-100">
            <div class="card-body">
                <div class="metric-label">Lokaler Routenspeicher</div>
                <div class="support-value">@_flightPath.Count/50 Tracking-Punkte</div>
            </div>
        </div>
    </div>
</div>

@code {
    private const int MaxFlightPathPoints = 50;
    private static readonly TimeSpan RefreshInterval = TimeSpan.FromSeconds(5);

    private readonly List<FlightPathPoint> _flightPath = [];
    private readonly CancellationTokenSource _cancellationTokenSource = new();

    private IssTelemetry? _telemetry;
    private PeriodicTimer? _timer;
    private Task? _trackingTask;
    private bool _isInitialLoading = true;
    private bool _isRefreshing;
    private bool _isMapReady;
    private string? _errorMessage;
    private string? _locationWarning;
    private string? _mapErrorMessage;
    private string? _storageWarning;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await InitializeMapAsync();
        await LoadStoredFlightPathAsync(_cancellationTokenSource.Token);
        await RefreshIssDataAsync(isInitialLoad: true, _cancellationTokenSource.Token);

        _timer = new PeriodicTimer(RefreshInterval);
        _trackingTask = RunTrackingLoopAsync(_cancellationTokenSource.Token);
    }

    private async Task RunTrackingLoopAsync(CancellationToken cancellationToken)
    {
        if (_timer is null)
        {
            return;
        }

        try
        {
            while (await _timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await RefreshIssDataAsync(isInitialLoad: false, cancellationToken);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task InitializeMapAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("initializeIssMapRuntime", "iss-map");
            _isMapReady = true;
            _mapErrorMessage = null;
        }
        catch (JSException)
        {
            _mapErrorMessage = "Die Karte konnte nicht initialisiert werden. Bitte die Seite neu laden oder die Netzwerkverbindung prüfen.";
        }
    }

    private async Task RefreshIssDataAsync(bool isInitialLoad, CancellationToken cancellationToken)
    {
        _errorMessage = null;

        if (isInitialLoad)
        {
            _isInitialLoading = true;
        }
        else
        {
            _isRefreshing = true;
            StateHasChanged();
        }

        try
        {
            var position = await IssApi.GetCurrentPositionAsync(cancellationToken);
            var locationLabel = await ResolveLocationLabelAsync(position, cancellationToken);

            _telemetry = position with { LocationLabel = locationLabel };
            AddFlightPathPoint(_telemetry);
            await SaveFlightPathAsync(cancellationToken);

            if (_isMapReady)
            {
                await UpdateMapAsync(_telemetry, cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception)
        {
            _errorMessage = "Die ISS-Positionsdaten konnten nicht geladen werden. Bitte später erneut versuchen.";
        }
        finally
        {
            _isInitialLoading = false;
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private async Task<string> ResolveLocationLabelAsync(IssTelemetry position, CancellationToken cancellationToken)
    {
        try
        {
            _locationWarning = null;
            return await ReverseGeocoding.GetLocationLabelAsync(position.Latitude, position.Longitude, cancellationToken);
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception)
        {
            _locationWarning = "Reverse Geocoding ist aktuell nicht verfügbar. Die Position wird ohne Region angezeigt.";
            return BrowserReverseGeocodingService.OceanLocationLabel;
        }
    }

    private void AddFlightPathPoint(IssTelemetry telemetry)
    {
        if (_flightPath.Count > 0 && _flightPath[^1].Timestamp == telemetry.Timestamp)
        {
            return;
        }

        _flightPath.Add(new FlightPathPoint(telemetry.Latitude, telemetry.Longitude, telemetry.Timestamp));

        if (_flightPath.Count > MaxFlightPathPoints)
        {
            _flightPath.RemoveRange(0, _flightPath.Count - MaxFlightPathPoints);
        }
    }

    private async Task LoadStoredFlightPathAsync(CancellationToken cancellationToken)
    {
        try
        {
            var storedPoints = await JS.InvokeAsync<StoredFlightPathPoint[]>(
                "loadStoredFlightPathRuntime",
                cancellationToken);

            _flightPath.Clear();
            _flightPath.AddRange(storedPoints
                .Select(ParseStoredFlightPathPoint)
                .Where(point => point is not null)
                .Select(point => point!)
                .OrderBy(point => point.Timestamp)
                .TakeLast(MaxFlightPathPoints));

            if (_isMapReady && _flightPath.Count > 0)
            {
                await UpdateFlightPathAsync(cancellationToken);
            }
        }
        catch (JSException)
        {
            _storageWarning = "Die gespeicherte ISS-Route konnte nicht gelesen werden.";
        }
    }

    private async Task SaveFlightPathAsync(CancellationToken cancellationToken)
    {
        try
        {
            var storedPoints = _flightPath
                .TakeLast(MaxFlightPathPoints)
                .Select(point => new
                {
                    latitude = point.Latitude,
                    longitude = point.Longitude,
                    timestamp = point.Timestamp.ToString("O")
                })
                .ToArray();
            var storedPointsJson = System.Text.Json.JsonSerializer.Serialize(storedPoints);

            var savedCount = await JS.InvokeAsync<int>("saveFlightPathJsonRuntime", cancellationToken, storedPointsJson);

            if (savedCount == 0 && _flightPath.Count > 0)
            {
                _storageWarning = "Die ISS-Route wurde nicht lokal gespeichert.";
            }
            else
            {
                _storageWarning = null;
            }
        }
        catch (JSException)
        {
            _storageWarning = "Die ISS-Route konnte nicht lokal gespeichert werden.";
        }
    }

    private async Task UpdateMapAsync(IssTelemetry telemetry, CancellationToken cancellationToken)
    {
        var updatedAt = telemetry.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss");

        await JS.InvokeVoidAsync(
            "updateIssMapPosition",
            cancellationToken,
            telemetry.Latitude,
            telemetry.Longitude,
            telemetry.LocationLabel,
            updatedAt);

        await UpdateFlightPathAsync(cancellationToken);
    }

    private async Task UpdateFlightPathAsync(CancellationToken cancellationToken)
    {
        var points = _flightPath
            .Select(point => new[] { point.Latitude, point.Longitude })
            .ToArray();

        await JS.InvokeVoidAsync("updateIssMapFlightPath", cancellationToken, points);
    }

    private static bool IsValidCoordinate(double latitude, double longitude)
    {
        return latitude is >= -90 and <= 90 &&
            longitude is >= -180 and <= 180;
    }

    private static FlightPathPoint? ParseStoredFlightPathPoint(StoredFlightPathPoint point)
    {
        if (!IsValidCoordinate(point.Latitude, point.Longitude) ||
            !DateTimeOffset.TryParse(point.Timestamp, out var timestamp))
        {
            return null;
        }

        return new FlightPathPoint(point.Latitude, point.Longitude, timestamp);
    }

    private static string FormatCoordinate(double? value, char positiveSuffix, char negativeSuffix)
    {
        if (value is null)
        {
            return "--";
        }

        var suffix = value >= 0 ? positiveSuffix : negativeSuffix;
        return $"{Math.Abs(value.Value):F4}° {suffix}";
    }

    public async ValueTask DisposeAsync()
    {
        _cancellationTokenSource.Cancel();
        _timer?.Dispose();

        if (_trackingTask is not null)
        {
            try
            {
                await _trackingTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _cancellationTokenSource.Dispose();
    }

    private sealed record StoredFlightPathPoint(
        double Latitude,
        double Longitude,
        string Timestamp);
}
